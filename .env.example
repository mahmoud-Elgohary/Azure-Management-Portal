# WTS Azure Cloud Manager — environment configuration
# Copy to .env and fill in real values (run: python setup_env.py)

# WTS Azure AD tenant ID (GUID)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Service principal registered in WTS tenant (GUID)
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret for the service principal (keep secret)
AZURE_CLIENT_SECRET=your-client-secret-here

# Comma-separated list of WTS subscription IDs (GUIDs)
AZURE_SUBSCRIPTION_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Flask secret key — auto-generated by setup_env.py
FLASK_SECRET_KEY=replace-with-secrets-token-hex-32-output

# Port for this app (must differ from other apps on this VM; O365 app uses 5000)
APP_PORT=8050

# How often the background sync job pulls from Azure (minutes)
SYNC_INTERVAL_MINUTES=60

# ── Entra ID sign-in (Authorization Code flow) ──────────────────────────────
# Auto-derived by setup_env.py from AZURE_TENANT_ID — set manually if overriding
AUTHORITY=https://login.microsoftonline.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Redirect URI path registered in the Entra app registration
AUTH_REDIRECT_PATH=/auth/callback

# Optional: restrict access to members of this group (object ID GUID).
# Leave blank to allow any user in the tenant (rely on "Assignment required" in Entra).
ALLOWED_GROUP_ID=
